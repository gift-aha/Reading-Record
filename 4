    // 辅助函数：生成人物卡片HTML
    function buildCharList(containerId, characters) {
        const container = document.getElementById(containerId);
        if (!container) return;
        container.innerHTML = characters.map(c => `
            <div class="char-card-mini">
                <strong>${c.name}</strong>
                <span>${c.desc}</span>
            </div>
        `).join('');
    }

    // 创建网络图通用函数
    function createNetwork(containerId, nodesData, edgesData, optionsOverride = {}) {
        const container = document.getElementById(containerId);
        if (!container) return null;
        const nodes = new vis.DataSet(nodesData);
        const edges = new vis.DataSet(edgesData);
        const defaultOptions = {
            autoResize: true,
            height: '100%',
            width: '100%',
            layout: { improvedLayout: true, hierarchical: false },
            interaction: { hover: true, tooltipDelay: 200, navigationButtons: true },
            physics: {
                enabled: true,
                solver: 'forceAtlas2Based',
                forceAtlas2Based: { gravitationalConstant: -30, centralGravity: 0.01 },
                stabilization: { iterations: 120 }
            },
            edges: {
                smooth: { type: 'continuous' },
                font: { size: 10, align: 'middle', color: '#4a2f23', background: '#fdf1e8', strokeWidth: 0 },
                color: { inherit: 'from' },
                width: 1.8,
                arrows: { to: { enabled: false } }
            },
            nodes: {
                shape: 'dot',
                size: 22,
                font: { size: 11, color: '#2c1f18', face: 'Segoe UI', strokeWidth: 0 },
                borderWidth: 1.5,
                shadow: true
            }
        };
        const options = { ...defaultOptions, ...optionsOverride };
        return new vis.Network(container, { nodes, edges }, options);
    }

